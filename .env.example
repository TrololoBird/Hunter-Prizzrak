# Telegram runtime secrets
TG_TOKEN=your_telegram_bot_token_here
TARGET_CHAT_ID=your_target_chat_id_here


# Optional aliases (same as above)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_target_chat_id_here

# Operator console — private DM with the bot from any network (iPhone ≠ MacBook Wi‑Fi).
# Get your numeric id from @userinfobot, then add here (comma-separated for multiple admins).
TELEGRAM_OPERATOR_USER_IDS=
# Example: TELEGRAM_OPERATOR_USER_IDS=123456789

# GitHub — agent push, gh CLI, Cursor MCP (see docs/GITHUB_CURSOR_SETUP.md)
# Fine-grained PAT: Contents+PR+Actions+Workflows on this repo only.
GITHUB_TOKEN=your_github_pat_here

# Dashboard — required when dashboard_host=0.0.0.0
DASHBOARD_TOKEN=your_dashboard_token_here
CMC_API_KEY=your_coinmarketcap_api_key_here
# Hunt — early dump alert (DUMP PREP / DUMP IMMINENT before full confirm bar)
# Gives user 60-120s advance notice for manual entry preparation.
HUNT_EARLY_DUMP_TG=1
GOOGLE_API_KEY=your_google_api_key_here
HUNT_LONG_TG=1
# OpenCode mcpmarket-me MCP — Bearer token, substituted into opencode.jsonc via {env:MCPMARKET_TOKEN}
MCPMARKET_TOKEN=sk_user_replace_me
