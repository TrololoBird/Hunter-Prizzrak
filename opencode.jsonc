{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "command": {
    "test": {
      "description": "Run pytest suite",
      "template": "uv run pytest $ARGUMENTS"
    },
    "lint": {
      "description": "Run ruff check (lint) and mypy (type-check)",
      "template": "uv run ruff check . && uv run mypy hunt_core"
    },
    "watch": {
      "description": "Run the production watch loop",
      "template": "uv run python -m hunt_core watch $ARGUMENTS"
    },
    "smoke": {
      "description": "Run a single-pass smoke test (no telegram)",
      "template": "uv run python -m hunt_core watch --once --no-telegram"
    },
    "check": {
      "description": "Quick sanity: compile-all + ruff",
      "template": "uv run python -m compileall -q hunt_core && uv run ruff check ."
    },
    "typecheck": {
      "description": "Run mypy type-checker only",
      "template": "uv run mypy hunt_core"
    },
    "coverage": {
      "description": "Run tests with coverage report",
      "template": "uv run pytest --cov=hunt_core --cov-report=term-missing"
    },
    "log": {
      "description": "Tail the watch loop log",
      "template": "!tail -50 /tmp/hunt_live/watch.log"
    },
    "status": {
      "description": "Check if the watch process is running",
      "template": "!ps aux | grep hunt_core.watch | grep -v grep || echo 'Not running'"
    },
    "audit": {
      "description": "Full pre-commit: compile + ruff + mypy + pytest",
      "template": "uv run python -m compileall -q hunt_core && uv run ruff check . && uv run mypy hunt_core && uv run pytest"
    },
    "fix": {
      "description": "Auto-fix ruff issues",
      "template": "uv run ruff check --fix ."
    },
    "ccxt": {
      "description": "Diagnose CCXT connection to Binance Futures",
      "template": "uv run python -c \"import ccxt; b=ccxt.binance({'options':{'defaultType':'future'}}); b.load_markets(); print(f'OK: {len(b.markets)} markets loaded')\""
    },
    "commit": {
      "description": "Stage all and commit with conventional message",
      "template": "!git diff --cached --stat || (git add -A && echo 'Staged all'); \\!git diff --cached --stat; Write a concise conventional commit message (type(scope): description) for these changes. Commit with this message."
    },
    "pr": {
      "description": "Prepare PR: check status, diff, suggest title",
      "template": "!git status && echo '---' && !git diff --stat && echo '---' && !git log --oneline -10 origin/main..HEAD 2>/dev/null || !git log --oneline -10; Review the branch and suggest a PR title and description following conventional commits."
    },
    "review": {
      "description": "Review uncommitted changes for issues",
      "template": "!git diff --cached --stat && echo '---' && !git diff --cached; Review the staged changes. Check for: type safety with mypy, ruff lint issues, logic errors in signal detection patterns, and any ignored exception paths. Suggest fixes."
    },
    "skill-ccxt": {
      "description": "Load the CCXT Python skill",
      "template": "/skill ccxt-python"
    },
    "skill-hunter": {
      "description": "Load the crypto-hunter skill",
      "template": "/skill crypto-hunter"
    },
    "deps": {
      "description": "Verify dependencies are synced",
      "template": "uv sync --check || (echo 'Deps out of sync — run uv sync' && false)"
    },
    "clean": {
      "description": "Clean Python cache and temp files",
      "template": "find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null; find . -type f -name '*.pyc' -delete; rm -rf .mypy_cache .ruff_cache; echo 'Cleaned'"
    },
    "docs": {
      "description": "Generate or update documentation for specified code",
      "template": "Add or improve documentation for $ARGUMENTS. Include: purpose, parameters, return values, exceptions raised. Follow the existing docstyle in the project."
    },
    "explain": {
      "description": "Explain code or concept in detail",
      "template": "Explain how $ARGUMENTS works in this codebase. Include: purpose, flow, key components, and how it connects to the rest of the system."
    },
    "rmslop": {
      "description": "Remove AI-generated slop (emojis, chatty comments)",
      "template": "Review the code for AI slop: unnecessary comments, emojis in code, overly chatty docstrings, verbose logging, redundant type annotations. Remove them. Focus on making the code professional and concise."
    },
    "debug": {
      "description": "Debug common issues in the codebase",
      "template": "!tail -30 /tmp/hunt_live/watch.log 2>/dev/null || echo 'No watch log'; !uv run python -m compileall -q hunt_core 2>&1 | tail -20; Debug any issues found. Check: import errors, type mismatches, missing env vars, CCXT connection problems. Suggest fixes."
    },
    "test-gen": {
      "description": "Generate tests for specified module or function",
      "template": "Generate comprehensive pytest tests for $ARGUMENTS. Follow existing test patterns in the project. Include: happy path, edge cases, error handling. Use pytest fixtures and mocks where appropriate."
    },
    "issues": {
      "description": "Search for TODO, FIXME, HACK markers in code",
      "template": "!rg -n 'TODO|FIXME|HACK|XXX|BUG|WORKAROUND' --type py hunt_core/ 2>/dev/null || echo 'No issues found'; List all code issues found, categorize by severity, and suggest fixes for the most critical ones."
    }
  },
  "mcp": {
    "ccxt": {
      "type": "local",
      "command": ["uvx", "mcp-ccxt", "run"],
      "enabled": true
    },
    "mcpmarket-me": {
      "type": "remote",
      "url": "https://link.mcpmarket.com/undeadbird-sc2/toolkits/me/mcp",
      "headers": { "Authorization": "Bearer {env:MCPMARKET_TOKEN}" },
      "enabled": true
    }
  }
}
